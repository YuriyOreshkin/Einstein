
@{
    ViewBag.Title = "Расписание";
}
@Scripts.Render("~/Scripts/gridview.js")
@*<h2>Календарь мероприятий</h2>*@

<div id="events-content">
    
    <div id="filter-searcher" class="filter-section">
        <span class="k-textbox k-space-left" style="width: 100%;">
            @(Html.Kendo().TextBox().Name("searchbox").HtmlAttributes(new { placeholder = "Поиск" }))
            <span class="k-icon k-i-search"></span>
        </span>
    </div>

    @(Html.Kendo().Scheduler<Einstein.WebUI.Models.EventViewModel>()
                                        .Name("scheduler")
                                        .HtmlAttributes(new { style = "height: 100%" })
                                        .MajorTimeHeaderTemplate("#=kendo.toString(date, 'HH:mm')#")
                                        .Views(views =>
                                        {
                                            views.AgendaView();

                                        })
                                        
                                        .Editable(false)
                                        .EventTemplateId("eventCardsTemplate")
                                        .Timezone("W-SU")
                                        .Mobile(MobileMode.Auto)
                                        .Height(920)
                                        .DataSource(d => d
                                            .Model(m =>
                                            {
                                                m.Id(f => f.TaskID);
                                                
                                            })
                                            .Read("Read", "SchedulerService")
                                            .Events(events => events.Error("error_handler"))
                                        )
                                        
    )

</div>

<script id="eventCardsTemplate" type="text/x-kendo-template">
     <div class="k-card k-card-horizontal">
        <div class="k-card-media" style="background-color: #= Color #;width:30px;"></div>
       <div class="k-vbox k-column" style="width:100%">
         <div class="k-card-header">
                    <h5 class="k-card-title" >#= title#</h5>
                    <h6 class="k-card-subtitle">#= kendo.toString(start, 'dd.MM.yyyy dddd HH:mm' )# — #= kendo.toString(end, 'HH:mm' )#</h6>
         </div>
        #if(description){#
            <div class="k-card-body">
                <p>#= kendo.toString(description) #</p>
            </div>
        #}#
        <div class="k-card-actions k-actions-vertical k-actions-center">
             @*<span class="k-card-action">*@
                      <a class="action-order" target="_blank"  href="@Url.Action("Index","Order")?title=#=title#&start=#: kendo.toString(start, 'dd.MM.yyyy HH:mm' )#"> <span class="k-button k-flat k-primary" ><span class="k-icon k-i-cart"></span>Купить билет</span></a>
              @*</span>*@
        </div>
        <div class="k-card-footer">
                    <span class="event-info-item event-price"><span>Цена: </span><strong>#=kendo.toString(kendo.parseInt(Price), "c")#</strong></span>
                    #if(FreePlaces > 0 ){#
                     <span class="event-info-item" style="background-color: rgb(48,214,100);" ><span>Мест: </span> #= FreePlaces#</strong><span class="k-icon  k-i-user" style="font-size: 1px; padding-left: 5px;"></span></span>
                    #} else {#
                        <span class="event-info-item" style="background-color: rgb(255,48,100);" ><span>Мест нет</span></span>
                    #}#
         </div>
       </div>
        @*<hr class="k-card-separator k-separator-vertical">*@

    </div>
</script>   
<script>

    
   
    $(document).ready(function () {

        if (!kendo.support.mobileOS) {
            $(window).resize();
        }
    });

    $("#searchbox").on("input", function () {

        schedulerFiltering();
    });


    function schedulerFiltering() {
        var query = { logic: "or", filters: [{}] };
       
        //seacher
        var scheduler = $("#scheduler").data("kendoScheduler");
        
        var text = $("#searchbox").val();

        if (text.length > 0) {
            //Title or Content
            query.filters.push({
                logic: "or",
                filters: [
                    { field: "title", operator: "contains", value: text },
                ]
            });

            scheduler.dataSource.filter(query);
        }
        else {
            scheduler.dataSource.filter({});
        }




    }


    function setSchedulerHeight(height) {
        var widget = $("#scheduler").data("kendoScheduler");
        widget.element.height(height);
        $(".k-scheduler-content").height(height-80);
        widget.resize(true);
    }

    $(window).resize(function () {

        var wheight = $(window).outerHeight();
        var mMHeight = $("#mainMenu").height();
        var fHeight = $("#filter-searcher").height();
        
        setSchedulerHeight(wheight - mMHeight - fHeight-4);
    });



</script>
